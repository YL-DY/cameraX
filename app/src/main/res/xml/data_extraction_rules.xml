<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ 数据提取规则
    录像文件存储在 MediaStore 中，由系统管理备份
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
